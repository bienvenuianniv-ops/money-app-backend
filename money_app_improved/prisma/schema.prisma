generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TransactionType {
  TRANSFER
  DEPOSIT
  WITHDRAW
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum UserRole {
  USER
  ADMIN
  SYSTEM
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id          String     @id @default(uuid())
  phone       String     @unique
  countryCode String     @default("SN")   // ISO 3166-1 alpha-2 : SN, CI, CM, FR...
  dialCode    String     @default("+221") // ex: +221, +225, +237, +33
  pinHash     String
  role        UserRole   @default(USER)
  status      UserStatus @default(ACTIVE)

  // Sécurité PIN
  failedPinAttempts Int       @default(0)
  pinLockedUntil    DateTime?
  lastLoginAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets         Wallet[]
  auditsAsActor   AuditLog[]       @relation("AuditActor")
  auditsAsTarget  AuditLog[]       @relation("AuditTarget")
  idempotencyKeys IdempotencyKey[]

  @@index([countryCode])
  @@index([status])
}

// ─────────────────────────────────────────────
// WALLET (multi-devises)
// ─────────────────────────────────────────────

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  currency  String   // XOF, XAF, EUR, USD, GNF, MAD...
  balance   BigInt   @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  txFrom Transaction[] @relation("TxFrom")
  txTo   Transaction[] @relation("TxTo")

  @@unique([userId, currency])
  @@index([userId])
  @@index([currency])
}

// ─────────────────────────────────────────────
// TRANSACTION (multi-devises + taux de change)
// ─────────────────────────────────────────────

model Transaction {
  id   String            @id @default(uuid())
  type TransactionType   @default(TRANSFER)

  fromWalletId String
  toWalletId   String

  // Montants
  amount         BigInt  // montant dans la devise source
  fee            BigInt  @default(0)

  // Support multi-devises
  fromCurrency   String  // devise de l'expéditeur
  toCurrency     String  // devise du destinataire
  exchangeRate   Float   @default(1.0) // taux appliqué au moment de la tx
  convertedAmount BigInt // montant converti dans la devise cible

  status    TransactionStatus @default(PENDING)
  reference String?           @unique // référence externe lisible (ex: TXN-20260313-XXXX)
  note      String?           // note optionnelle de l'expéditeur

  createdAt DateTime @default(now())

  fromWallet Wallet @relation("TxFrom", fields: [fromWalletId], references: [id], onDelete: Restrict)
  toWallet   Wallet @relation("TxTo", fields: [toWalletId], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([status])
  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([fromCurrency])
  @@index([toCurrency])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// TAUX DE CHANGE (snapshot historique)
// ─────────────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency String
  toCurrency   String
  rate         Float
  source       String   @default("MANUAL") // MANUAL | API | FIXED
  fetchedAt    DateTime @default(now())

  @@index([fromCurrency, toCurrency])
  @@index([fetchedAt])
}

// ─────────────────────────────────────────────
// PAYS SUPPORTÉS
// ─────────────────────────────────────────────

model Country {
  code       String  @id // ISO 3166-1 alpha-2 : SN, CI, CM, FR...
  name       String
  dialCode   String  // +221, +225...
  currency   String  // XOF, XAF, EUR...
  isActive   Boolean @default(true)
  region     String  // CEDEAO | CEMAC | EUROPE | AUTRE

  @@index([currency])
  @@index([region])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// IDEMPOTENCY
// ─────────────────────────────────────────────

model IdempotencyKey {
  id           String   @id @default(uuid())
  key          String
  userId       String
  endpoint     String
  requestHash  String
  responseBody String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint, key], name: "userId_endpoint_key")
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  action        String
  actorUserId   String?
  targetUserId  String?
  ip            String?
  userAgent     String?
  severity      String   @default("INFO") // INFO | WARN | ERROR | CRITICAL
  requestId     String?
  correlationId String?
  metadata      Json?
  createdAt     DateTime @default(now())

  actor  User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([severity])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([requestId])
  @@index([correlationId])
  @@index([createdAt])
}
